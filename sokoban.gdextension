[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = true

[libraries]
linux.debug.x86_64 =     "res://extension/target/debug/libextension.so"
linux.release.x86_64 =   "res://extension/target/release/libextension.so"
windows.debug.x86_64 =   "res://extension/target/debug/extension.dll"
windows.release.x86_64 = "res://extension/target/release/extension.dll"
macos.debug =            "res://extension/target/debug/libextension.dylib"
macos.release =          "res://extension/target/release/libextension.dylib"
macos.debug.arm64 =      "res://extension/target/debug/libextension.dylib"
macos.release.arm64 =    "res://extension/target/release/libextension.dylib"
android.debug.arm64   =  "res://extension/target/aarch64-linux-android/release/libextension.so"
android.release.arm64 =  "res://extension/target/aarch64-linux-android/release/libextension.so"
web.debug.wasm32 =       "res://extension/target/wasm32-unknown-emscripten/debug/extension.wasm"
web.release.wasm32 =     "res://extension/target/wasm32-unknown-emscripten/release/extension.wasm"
