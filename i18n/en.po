msgstr "Screen Space AA"

msgid "SCREEN_SPACE_AA_TIP"
msgstr ""
"Screen-space anti-aliasing methods\n"
"[ul]"
"[b]SMAA[/b] (Enhanced Subpixel Morphological Antialiasing)\r"
"[b]Quality[/b]: High, [b]Overhead[/b]: [color=yellow]Medium[/color]\n"
"[b]FXAA[/b] (Fast Approximate Anti-Aliasing)\r"
"[b]Quality[/b]: Low, [b]Overhead[/b]: [color=green]Low[/color]"
"[/ul]"

msgid "SMAA"
msgstr "SMAA"

msgid "FXAA"
msgstr "FXAA"

msgid "TAA"
msgstr "TAA"

msgid "TAA_TIP"
