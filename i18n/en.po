msgstr "Visualize lower bounds as a heatmap"

msgid "TUNNELS"
msgstr "Tunnels"

msgid "TUNNELS_TIP"
msgstr "Visualize tunnels"

# Video

msgid "VIDEO"
msgstr "Video"

msgid "DISPLAY"
msgstr "Display"

msgid "WINDOW_MODE"
msgstr "Window Mode"

msgid "WINDOW_MODE_TIP"
msgstr ""
"Choose window mode\n"
"[ul]"
"[b]Windowed[/b]\n"
"[b]Maximized[/b]\n"
"[b]Borderless fullscreen[/b]\n"
"[b]Exclusive fullscreen[/b]"
"[/ul]"

msgid "WINDOWED"
msgstr "Windowed"

msgid "MAXIMIZED"
msgstr "Maximized"

msgid "BORDERLESS_FULLSCREEN"
msgstr "Borderless Fullscreen"

msgid "EXCLUSIVE_FULLSCREEN"
msgstr "Exclusive Fullscreen"

msgid "VSYNC"
msgstr "VSync"

msgid "VSYNC_TIP"
msgstr "Toggle vertical sync to reduce screen tearing, but also limits the maximum frame rate"

msgid "FRAME_RATE_LIMIT"
msgstr "Frame Rate Limit"

msgid "FRAME_RATE_LIMIT_TIP"
msgstr "Limit the maximum frame rate"

msgid "UNLIMITED"
msgstr "Unlimited"

msgid "GRAPHICS"
msgstr "Graphics"

msgid "FIELD_OF_VIEW"
msgstr "Field of View"

msgid "FIELD_OF_VIEW_TIP"
msgstr "Adjust the camera's field of view"

msgid "SCALING_AND_AA"
msgstr "Resolution Scaling & Anti-Aliasing"

msgid "SCALING_METHOD"
msgstr "Scaling Method"

msgid "SCALING_METHOD_TIP"
msgstr ""
"3D rendering upscale method\n"
"[ul]"
"[b]Bilinear[/b]: Simple bilinear interpolation\n"
"[b]FSR 1.0[/b]\r"
"[b]Quality[/b]: Medium, [b]Overhead[/b]: [color=green]Low[/color]\n"
"[b]FSR 2.2[/b]\r"
"[b]Quality[/b]: High, [b]Overhead[/b]: [color=yellow]High[/color]"
"[/ul]"

msgid "UPSCALED_RESOLUTION"
msgstr "Upscaled Resolution"

msgid "UPSCALED_RESOLUTION_TIP"
msgstr "Adjust the internal 3D rendering resolution scale. Lower values improve performance at the cost of image quality"

msgid "FSR_SHARPNESS"
msgstr "FSR Sharpness"

msgid "FSR_SHARPNESS_TIP"
msgstr "Adjust the sharpness of FSR upscaling. Lower values are sharper, higher values are softer"

msgid "SCREEN_SPACE_AA"
msgstr "Screen Space AA"

msgid "SCREEN_SPACE_AA_TIP"
msgstr ""
"Screen-space anti-aliasing methods\n"
"[ul]"
"[b]SMAA[/b] (Enhanced Subpixel Morphological Antialiasing)\r"
"[b]Quality[/b]: Medium, [b]Overhead[/b]: [color=yellow]Low[/color]\n"
"[b]FXAA[/b] (Fast Approximate Anti-Aliasing)\r"
"[b]Quality[/b]: Low, [b]Overhead[/b]: [color=green]Very Low[/color]"
"[/ul]"

msgid "SMAA"
msgstr "SMAA"

msgid "FXAA"
msgstr "FXAA"

msgid "TAA"
msgstr "TAA"

msgid "TAA_TIP"
msgstr ""
"Temporal anti-aliasing\n"
"[b]Quality[/b]: High, [b]Overhead[/b]: [color=yellow]Medium[/color]"

msgid "MSAA"
msgstr "MSAA"

msgid "MSAA_TIP"
msgstr ""
"Multisample anti-aliasing\n"
"[b]Quality[/b]: Medium, [b]Overhead[/b]: [color=yellow]Medium[/color]"

msgid "DISABLED"
msgstr "Disabled"

