msgstr "Solver"

msgid "ALGORITHM"
msgstr "Algorithm"

msgid "ALGORITHM_TIP"
msgstr ""
"Select the search algorithm\n"
"[ul]"
"[b]A*[/b]: Fast, extremely high memory footprint\n"
"[b]IDA*[/b]: Slower, low memory footprint"
"[/ul]"

msgid "STRATEGY"
msgstr "Strategy"

msgid "STRATEGY_TIP"
msgstr ""
"Solver Strategy\n"
"[ul]"
"[b]Quick[/b]: Quickly find any solution\n"
"[b]Push-Optimal[/b]: Find the optimal solution with the least pushes\n"
"[b]Move-Optimal[/b]: Find the optimal solution with the least moves"
"[/ul]"

