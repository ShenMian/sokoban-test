"[b]FXAA[/b] (快速近似抗锯齿)\r"
"[b]质量[/b]: 低, [b]开销[/b]: [color=green]低[/color]"
"[/ul]"

msgid "SMAA"
msgstr "SMAA"

msgid "FXAA"
msgstr "FXAA"

msgid "TAA"
msgstr "TAA"

msgid "TAA_TIP"
msgstr ""
"时间抗锯齿\n"
"[b]质量[/b]: 高, [b]开销[/b]: [color=yellow]中[/color]"

msgid "MSAA"
msgstr "MSAA"

