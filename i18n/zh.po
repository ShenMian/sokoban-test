msgstr "分辨率缩放与抗锯齿"

msgid "SCALING_METHOD"
msgstr "缩放方法"

msgid "SCALING_METHOD_TIP"
msgstr ""
"3D 渲染放大方法\n"
"[ul]"
"[b]双线性[/b]: 简单双线性插值\n"
"[b]FSR 1.0[/b]\r"
"[b]质量[/b]: 中, [b]开销[/b]: [color=green]低[/color]\n"
"[b]FSR 2.2[/b]\r"
"[b]质量[/b]: 高, [b]开销[/b]: [color=yellow]中[/color]"
"[/ul]"

